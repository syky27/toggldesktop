# Redtick iOS code signing → TestFlight (direct — no match).
#
# The iOS Distribution cert+key is imported into the CI keychain by the workflow
# (the "Build + upload to TestFlight" step in ios-release.yml) — same approach
# that works for the macOS Developer ID cert. Here we fetch the existing App
# Store provisioning profiles via the App Store Connect API key (read-only, no
# portal changes), force manual signing, archive with gym, and upload.
#
# No `match`, no certs repo, no MATCH_* secrets — that path proved too fragile on
# an Apple account with pre-existing certs.

opt_out_usage

MAIN_APP_ID = "cz.syky.redtick.redtick".freeze
EXT_APP_ID  = "cz.syky.redtick.redtick.RedtickLiveActivity".freeze

# App Store Connect API key from base64 env (profile download + TestFlight upload).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
    is_key_content_base64: true,
    in_house: false,
  )
end

platform :ios do
  # Build the .ipa and upload to TestFlight. The distribution cert is already in
  # the keychain (imported by the workflow). Run after, in the workflow:
  #   flutter pub get
  #   flutter build ios --config-only --release --no-codesign --build-name/number
  #   (cd ios && pod install)
  lane :beta do
    api_key = asc_api_key
    team = ENV.fetch("APPLE_TEAM_ID")

    # Download (read-only) the existing App Store profiles for both bundle ids and
    # install them. sigh exports the profile names as `sigh_<id>_appstore_*` env.
    get_provisioning_profile(api_key: api_key, app_identifier: MAIN_APP_ID, readonly: true)
    get_provisioning_profile(api_key: api_key, app_identifier: EXT_APP_ID, readonly: true)
    main_profile = ENV.fetch("sigh_#{MAIN_APP_ID}_appstore_profile-name")
    ext_profile  = ENV.fetch("sigh_#{EXT_APP_ID}_appstore_profile-name")

    # Force manual signing with those profiles (keeps the committed pbxproj
    # team-agnostic — CI mutates it on the throwaway runner).
    update_code_signing_settings(
      path: "ios/Runner.xcodeproj", use_automatic_signing: false, team_id: team,
      targets: ["Runner"], bundle_identifier: MAIN_APP_ID,
      code_sign_identity: "Apple Distribution", profile_name: main_profile,
    )
    update_code_signing_settings(
      path: "ios/Runner.xcodeproj", use_automatic_signing: false, team_id: team,
      targets: ["RedtickLiveActivityExtension"], bundle_identifier: EXT_APP_ID,
      code_sign_identity: "Apple Distribution", profile_name: ext_profile,
    )

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios-ipa",
      output_name: "Redtick.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team,
        # The extension must use its own profile (its App Group entitlement).
        provisioningProfiles: {
          MAIN_APP_ID => main_profile,
          EXT_APP_ID => ext_profile,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios-ipa/Redtick.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end
