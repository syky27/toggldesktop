# Redtick iOS code signing → TestFlight.
#   match `appstore` installs the Apple Distribution cert + App Store profiles for
#   the main app and the Live Activity extension (readonly in CI). Auth uses one
#   App Store Connect API key (.p8) from a base64 env var.
#
# macOS Developer ID signing is NOT handled here — it's done directly in
# .github/workflows/desktop-release.yml from a .p12 secret, because `match`
# cannot reliably manage Developer ID certificates. See docs/RELEASE_SIGNING.md.

opt_out_usage

MAIN_APP_ID = "cz.syky.redtick.redtick".freeze
EXT_APP_ID  = "cz.syky.redtick.redtick.RedtickLiveActivity".freeze

# App Store Connect API key from base64 env (shared by match + TestFlight upload).
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_P8_BASE64"),
    is_key_content_base64: true,
    in_house: false,
  )
end

before_all do
  setup_ci if ENV["CI"] # ephemeral signing keychain on CI; no-op locally
end

platform :ios do
  # Install the Apple Distribution cert + App Store profiles for both bundle ids.
  lane :certs do
    match(type: "appstore", app_identifier: [MAIN_APP_ID, EXT_APP_ID],
          api_key: asc_api_key, readonly: true)
  end

  # Build the .ipa and upload to TestFlight. Run after, in the workflow:
  #   flutter pub get
  #   flutter build ios --config-only --release --build-name=<v> --build-number=<n>
  #   (cd ios && pod install)
  lane :beta do
    api_key = asc_api_key
    certs
    team = ENV.fetch("APPLE_TEAM_ID")

    # match exports the installed profile names as env vars.
    main_profile = ENV.fetch("sigh_#{MAIN_APP_ID}_appstore_profile-name")
    ext_profile  = ENV.fetch("sigh_#{EXT_APP_ID}_appstore_profile-name")

    # Force manual signing with the match profiles on both targets (keeps the
    # committed pbxproj team-agnostic — CI mutates it on the throwaway runner).
    update_code_signing_settings(
      path: "ios/Runner.xcodeproj", use_automatic_signing: false, team_id: team,
      targets: ["Runner"], bundle_identifier: MAIN_APP_ID,
      code_sign_identity: "Apple Distribution", profile_name: main_profile,
    )
    update_code_signing_settings(
      path: "ios/Runner.xcodeproj", use_automatic_signing: false, team_id: team,
      targets: ["RedtickLiveActivityExtension"], bundle_identifier: EXT_APP_ID,
      code_sign_identity: "Apple Distribution", profile_name: ext_profile,
    )

    build_app(
      workspace: "ios/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ios-ipa",
      output_name: "Redtick.ipa",
      export_options: {
        signingStyle: "manual",
        teamID: team,
        # The extension MUST use its own profile (its App Group entitlement), not
        # the main app's — two entries here.
        provisioningProfiles: {
          MAIN_APP_ID => main_profile,
          EXT_APP_ID => ext_profile,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios-ipa/Redtick.ipa",
      skip_waiting_for_build_processing: true,
    )
  end
end
