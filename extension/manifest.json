{
  "manifest_version": 3,
  "name": "Redtick — Start timer on Redmine issue",
  "version": "1.0.0",
  "description": "Adds a \"Start in Redtick\" button to Redmine issue pages that starts a timer in the Redtick desktop app.",
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "scripting"],
  "optional_host_permissions": ["*://*/*"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Redtick",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "redtick@syky.cz",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["browsingActivity"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
